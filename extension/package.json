{
  "name": "hivecode",
  "displayName": "Hivecode — multiplayer for AI coding agents",
  "description": "Run humans and multiple AI agents on one live codebase, with folder-scoped permissions and approval gates. No git push/pull.",
  "version": "0.8.0",
  "publisher": "hivecode",
  "license": "MIT",
  "icon": "resources/icon.png",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "AI",
    "Other"
  ],
  "keywords": [
    "ai agents",
    "multi-agent",
    "claude",
    "cursor",
    "collaboration",
    "live share",
    "pair programming",
    "realtime",
    "multiplayer",
    "mcp"
  ],
  "galleryBanner": {
    "color": "#0a0c10",
    "theme": "dark"
  },
  "homepage": "https://github.com/GSK7024/livecode",
  "bugs": {
    "url": "https://github.com/GSK7024/livecode/issues"
  },
  "qna": false,
  "repository": {
    "type": "git",
    "url": "https://github.com/GSK7024/livecode"
  },
  "main": "./extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "hivecode",
          "title": "Hivecode",
          "icon": "resources/hive.svg"
        }
      ]
    },
    "views": {
      "hivecode": [
        {
          "type": "webview",
          "id": "hivecode.panel",
          "name": "Session"
        }
      ]
    },
    "commands": [
      {
        "command": "hivecode.host",
        "title": "Hivecode: Host an Open Session"
      },
      {
        "command": "hivecode.hostSecured",
        "title": "Hivecode: Host a Secured Session"
      },
      {
        "command": "hivecode.join",
        "title": "Hivecode: Join a Session"
      },
      {
        "command": "hivecode.invite",
        "title": "Hivecode: Invite to folders…"
      },
      {
        "command": "hivecode.manage",
        "title": "Hivecode: Manage access"
      },
      {
        "command": "hivecode.controlRoom",
        "title": "Hivecode: Open Control Room (browser / phone)"
      },
      {
        "command": "hivecode.restore",
        "title": "Hivecode: Restore a file to an earlier point…"
      },
      {
        "command": "hivecode.revertAgent",
        "title": "Hivecode: Revert an author's changes…"
      },
      {
        "command": "hivecode.undo",
        "title": "Hivecode: Undo my last synced edit"
      },
      {
        "command": "hivecode.redo",
        "title": "Hivecode: Redo my last undone edit"
      },
      {
        "command": "hivecode.leave",
        "title": "Hivecode: Leave Session"
      },
      {
        "command": "hivecode.endRoom",
        "title": "Hivecode: End Room (forget & start fresh)"
      }
    ],
    "keybindings": [
      {
        "command": "hivecode.undo",
        "key": "ctrl+alt+z",
        "mac": "cmd+alt+z"
      },
      {
        "command": "hivecode.redo",
        "key": "ctrl+alt+shift+z",
        "mac": "cmd+alt+shift+z"
      }
    ],
    "configuration": {
      "title": "Hivecode",
      "properties": {
        "hivecode.relayUrl": {
          "type": "string",
          "default": "wss://livecode-xoss.onrender.com",
          "description": "The Hivecode relay server URL."
        },
        "hivecode.displayName": {
          "type": "string",
          "default": "",
          "description": "Your name shown to others in the session. Leave blank for an auto-generated id."
        },
        "hivecode.participantKind": {
          "type": "string",
          "enum": [
            "human",
            "ai"
          ],
          "default": "human",
          "description": "How this window appears in the member list. Set to 'ai' for a window driven by an AI agent."
        },
        "hivecode.token": {
          "type": "string",
          "default": "",
          "description": "Access token for a secured (auth-required) relay. Leave blank for open rooms."
        }
      }
    }
  },
  "scripts": {
    "package": "vsce package",
    "publish:vsce": "vsce publish",
    "publish:ovsx": "ovsx publish"
  },
  "dependencies": {
    "ignore": "^5.3.2",
    "ws": "^8.18.0",
    "y-websocket": "^2.0.4",
    "yjs": "^13.6.18"
  },
  "devDependencies": {
    "@vscode/vsce": "^3.9.2"
  }
}
